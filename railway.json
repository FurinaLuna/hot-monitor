{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "startCommand": "sh -c 'npx prisma migrate deploy && node dist/index.js'"
  },
  "volumes": [
    {
      "name": "sqlite_data",
      "mountPath": "/app/data"
    }
  ]
}
